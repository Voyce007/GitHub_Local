# Copy to .env and adjust if you change any defaults in docker-compose.yml.
# Nothing here is a secret that leaves your laptop.

POSTGRES_USER=sdlc
POSTGRES_PASSWORD=sdlc_local_dev
POSTGRES_DB=sdlc

MINIO_ROOT_USER=sdlc_admin
MINIO_ROOT_PASSWORD=sdlc_local_dev

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

GRAFANA_ADMIN_PASSWORD=admin

DEFAULT_MODEL=llama3.1:8b

# jira-service — real Jira Cloud credentials, not a local dev-only secret.
# Fill these in directly in your own .env; JIRA_API_TOKEN is a real API
# token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
